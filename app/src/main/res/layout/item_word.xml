<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="word"
            type="com.example.bcsd_android_2025_1.WordListData" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <ImageView
            android:id="@+id/recyclerview_imageview"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/recyclerview_word_textview"
            android:text="@{word.word}"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            android:layout_margin="10dp"
            android:layout_marginEnd="20dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@+id/recyclerview_imageview"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:text="@{word.meaning}"
            android:textSize="15sp"
            android:layout_marginTop="20dp"
            android:layout_margin="10dp"
            android:layout_marginEnd="20dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            app:layout_constraintTop_toBottomOf="@+id/recyclerview_word_textview"
            app:layout_constraintStart_toEndOf="@+id/recyclerview_imageview"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>