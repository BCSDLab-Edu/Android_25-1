<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#fcf7fe"
    >

    <TextView
        android:id="@+id/textview_social_login_login"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="로그인"
        android:layout_weight="1"
        android:textSize="30sp"
        android:textStyle="bold"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_weight="1"
        >
        <EditText
            android:id="@+id/edittext_social_login_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="아이디"
            />

        <EditText
            android:id="@+id/edittext_social_login_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="비밀번호"
            />

        <Button
            android:id="@+id/button_social_login_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="로그인"
            android:layout_gravity="center"
            />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            >
            <ImageButton
                android:id="@+id/imagebutton_social_login_google"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_logo_google"
                android:padding="0sp"
                android:scaleType="centerCrop"
                android:background="#00ff0000"
                android:layout_margin="10dp"
            />
            <ImageButton
                android:id="@+id/imagebutton_social_login_naver"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_logo_naver"
                android:padding="0sp"
                android:scaleType="centerCrop"
                android:background="#00ff0000"
                android:layout_margin="10dp"
                />
            <ImageButton
                android:id="@+id/imagebutton_social_login_kakao"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_logo_kakao"
                android:padding="0sp"
                android:scaleType="centerCrop"
                android:background="#00ff0000"
                android:layout_margin="10dp"
                />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            >

            <Button
                android:id="@+id/button_social_login_find_password"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="#00ff0000"
                android:text="비밀번호 찾기"
                android:textColor="#000000"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingTop="0dp"
                />

            <Button
                android:id="@+id/button_social_login_create_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#00ff0000"
                android:text="가입하기"
                android:textColor="#000000"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingTop="0dp"
                />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>