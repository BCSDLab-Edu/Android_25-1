<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/text_login_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/main_number"
        android:textSize="30sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/button_login_toast"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="140sp"
        android:layout_marginEnd="20sp"
        android:background="@drawable/rectangle"
        android:text="@string/main_toastButton"
        android:textSize="15sp"
        app:layout_constraintEnd_toStartOf="@+id/button_login_count"
        app:layout_constraintHeight_percent="0.06"
        app:layout_constraintTop_toBottomOf="@id/text_login_number" />

    <Button
        android:id="@+id/button_login_count"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="140sp"
        android:text="@string/main_countButton"
        android:textSize="15sp"
        android:background="@drawable/rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.06"
        app:layout_constraintTop_toBottomOf="@id/text_login_number" />

    <Button
        android:id="@+id/button_login_random"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="140sp"
        android:layout_marginStart="20sp"
        android:text="@string/main_randomButton"
        android:textSize="15sp"
        android:background="@drawable/rectangle"
        app:layout_constraintStart_toEndOf="@+id/button_login_count"
        app:layout_constraintHeight_percent="0.06"
        app:layout_constraintTop_toBottomOf="@id/text_login_number" />

</androidx.constraintlayout.widget.ConstraintLayout>
