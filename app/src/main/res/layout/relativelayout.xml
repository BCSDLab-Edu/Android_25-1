<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#EDE7F6">


    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp" />


    <EditText
        android:id="@+id/emailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/titleText"
        android:layout_marginTop="40dp"
        android:hint="아이디"
        android:inputType="textEmailAddress"
        android:padding="15dp"
        android:minHeight="48dp"
        android:backgroundTint="#673AB7" />


    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/emailInput"
        android:layout_marginTop="16dp"
        android:hint="비밀번호"
        android:inputType="textPassword"
        android:minHeight="48dp"
        android:padding="15dp" />


    <Button
        android:id="@+id/loginButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/passwordInput"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:text="로그인"
        android:textSize="20sp" />


    <ImageView
        android:id="@+id/iconNaver"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_below="@id/loginButton"
        android:layout_marginTop="28dp"
        android:layout_centerHorizontal="true"
        app:srcCompat="@drawable/ic_logo_naver"
         />

    <ImageView
        android:id="@+id/iconGoogle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignTop="@id/iconNaver"
        android:layout_toStartOf="@id/iconNaver"
        android:layout_marginEnd="20dp"
        app:srcCompat="@drawable/ic_logo_google" />

    <ImageView
        android:id="@+id/iconKakao"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignTop="@id/iconNaver"
        android:layout_toEndOf="@id/iconNaver"
        android:layout_marginStart="20dp"
        app:srcCompat="@drawable/ic_logo_kakao" />


    <TextView
        android:id="@+id/findPasswordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@+id/iconGoogle"
        android:layout_below="@id/iconGoogle"
        android:layout_marginTop="28dp"
        android:text="비밀번호 찾기"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/joinText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/iconKakao"
        android:layout_alignEnd="@id/iconKakao"
        android:layout_marginTop="28dp"
        android:text="가입하기"
        android:textSize="12sp" />

</RelativeLayout>
