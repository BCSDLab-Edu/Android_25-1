<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fcf7fe"
    >

    <TextView
        android:id="@+id/textview_social_login_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:textSize="30sp"
        android:textStyle="bold"
        android:layout_above="@id/edittext_social_login_id"
        android:layout_centerHorizontal="true"
        android:layout_marginVertical="100dp"
        />

    <EditText
        android:id="@+id/edittext_social_login_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/edittext_social_login_password"
        android:layout_marginHorizontal="20dp"
        android:hint="아이디"/>

    <EditText
        android:id="@+id/edittext_social_login_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="20dp"
        android:hint="비밀번호"/>

    <Button
        android:id="@+id/button_social_login_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="로그인"
        android:layout_below="@id/edittext_social_login_password"
        android:layout_centerHorizontal="true"
        />

    <ImageButton
        android:id="@+id/imagebutton_social_login_google"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_google"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:background="00ff0000"
        android:layout_toStartOf="@id/imageButton_naver"
        android:layout_alignTop="@id/imageButton_naver"
        />

    <ImageButton
        android:id="@+id/imageButton_naver"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_naver"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:background="00ff0000"
        android:layout_margin="10dp"
        android:layout_below="@id/button_social_login_login"
        android:layout_centerHorizontal="true"
        />

    <ImageButton
        android:id="@+id/imagebutton_social_login_kakao"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_kakao"
        android:padding="0sp"
        android:scaleType="centerCrop"
        android:background="00ff0000"
        android:layout_toEndOf="@id/imageButton_naver"
        android:layout_alignTop="@id/imageButton_naver"
        />

    <Button
        android:id="@+id/button_social_login_find_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="00ff0000"
        android:text="비밀번호 찾기"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:paddingLeft="0dp"
        android:layout_marginTop="10dp"
        android:textColor="#000000"
        android:stateListAnimator="@null"
        android:layout_alignLeft="@id/imagebutton_social_login_google"
        android:layout_below="@id/imagebutton_social_login_google"
        />

    <Button
        android:id="@+id/button_social_login_create_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="00ff0000"
        android:text="가입하기"
        android:textColor="#000000"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:paddingLeft="0dp"
        android:layout_marginTop="10dp"
        android:stateListAnimator="@null"
        android:layout_alignRight="@id/imagebutton_social_login_kakao"
        android:layout_below="@id/imagebutton_social_login_google"
        />
</RelativeLayout>