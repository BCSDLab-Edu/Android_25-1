<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/text_login"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:gravity="bottom|center"
        android:text="로그인"
        android:textSize="35dp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_id"
        android:layout_width="match_parent"
        android:layout_height="135dp"
        android:gravity="bottom"
        android:paddingStart="35dp"
        android:text="아이디"
        android:textColor="#8C8C8C"
        android:textSize="20dp" />

    <View
        android:id="@+id/id_line"
        android:layout_width="340dp"
        android:layout_height="2dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="3dp"
        android:background="#5D5D5D" />

    <TextView
        android:id="@+id/text_password"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="bottom"
        android:paddingStart="35dp"
        android:text="비밀번호"
        android:textColor="#8C8C8C"
        android:textSize="20dp" />

    <View
        android:id="@+id/password_line"
        android:layout_width="340dp"
        android:layout_height="2dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="3dp"
        android:background="#5D5D5D" />

    <Button
        android:id="@+id/button_login"
        android:layout_width="110dp"
        android:layout_height="55dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="15dp"
        android:text="로그인"
        android:textSize="15dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="15dp">

        <ImageView
            android:id="@+id/image_google"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo_google"
            android:layout_marginEnd="15dp" />

        <ImageView
            android:id="@+id/image_naver"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/ic_logo_naver" />

        <ImageView
            android:id="@+id/image_kakao"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo_kakao" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="15dp">

        <TextView
            android:id="@+id/text_password_find"
            android:layout_width="90dp"
            android:layout_height="20dp"
            android:layout_gravity="center_horizontal"
            android:text="비밀번호 찾기"
            android:textColor="#5D5D5D"
            android:textSize="15dp"
            android:layout_marginEnd="15dp"/>

        <TextView
            android:id="@+id/text_signup"
            android:layout_width="60dp"
            android:layout_height="20dp"
            android:layout_gravity="center_horizontal"
            android:text="가입하기"
            android:textColor="#5D5D5D"
            android:textSize="15dp" />
    </LinearLayout>

</LinearLayout>