<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/textview_login_beginner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="180dp"/>

    <EditText
        android:id="@+id/edittext_login_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/id_hint"
        app:layout_constraintTop_toBottomOf="@id/textview_login_beginner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <EditText
        android:id="@+id/edittext_login_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/password_hint"
        app:layout_constraintTop_toBottomOf="@id/edittext_login_id"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/button_login_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_button"
        app:layout_constraintTop_toBottomOf="@id/edittext_login_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageButton
        android:id="@+id/imagebutton_login_google"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_google"
        app:layout_constraintTop_toBottomOf="@id/button_login_button"
        app:layout_constraintEnd_toStartOf="@id/imagebutton_login_naver"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginEnd="10dp"/>

    <ImageButton
        android:id="@+id/imagebutton_login_naver"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_naver"
        app:layout_constraintTop_toBottomOf="@id/button_login_button"
        app:layout_constraintStart_toEndOf="@id/imagebutton_login_google"
        app:layout_constraintEnd_toStartOf="@id/imagebutton_login_kakao"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginEnd="10dp"/>

    <ImageButton
        android:id="@+id/imagebutton_login_kakao"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_kakao"
        app:layout_constraintTop_toBottomOf="@id/button_login_button"
        app:layout_constraintStart_toEndOf="@id/imagebutton_login_naver"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/textview_login_findpassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/find_password"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/imagebutton_login_google"
        app:layout_constraintEnd_toStartOf="@id/textview_login_or"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginEnd="10sp"/>

    <TextView
        android:id="@+id/textview_login_or"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="|"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/imagebutton_login_google"
        app:layout_constraintStart_toEndOf="@id/textview_login_findpassword"
        app:layout_constraintEnd_toStartOf="@id/textview_login_register"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginEnd="10sp"/>

    <TextView
        android:id="@+id/textview_login_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/register"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/imagebutton_login_google"
        app:layout_constraintStart_toEndOf="@id/textview_login_or"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>