<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity">


        <TextView
            android:id="@+id/tv_main_word"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_main_note_word"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="30dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="30dp"/>

        <TextView
            android:id="@+id/tv_main_mean"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tv_main_note_mean"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="@id/tv_main_word"
            app:layout_constraintTop_toTopOf="@id/image_btn_main_edit"
            android:layout_marginTop="10dp"/>

        <ImageButton
            android:id="@+id/image_btn_main_delete"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:srcCompat="@android:drawable/ic_menu_delete"
            android:contentDescription="@string/image_btn_delete"
            app:layout_constraintTop_toTopOf="@id/tv_main_word"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="30dp"/>

        <ImageButton
            android:id="@+id/image_btn_main_edit"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:srcCompat="@android:drawable/ic_menu_edit"
            android:contentDescription="@string/image_btn_edit"
            app:layout_constraintTop_toBottomOf="@id/image_btn_main_delete"
            app:layout_constraintEnd_toEndOf="@id/image_btn_main_delete"/>

        <ImageButton
            android:id="@+id/image_btn_main_plus"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:srcCompat="@android:drawable/ic_input_add"
            android:contentDescription="@string/image_btn_plus"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="30dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/image_btn_main_edit"
            android:layout_marginTop="40dp"
            app:layout_constraintBottom_toTopOf="@id/image_btn_main_plus"
            android:layout_marginBottom="15dp"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>