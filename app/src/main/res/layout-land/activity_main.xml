<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <TextView
        android:id="@+id/text_login_title"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="bottom|center"
        android:text="@string/login_login"
        android:textSize="35sp"
        android:textStyle="bold"
        android:textColor="@color/text"
        app:layout_constraintBottom_toTopOf="@id/text_login_id"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_login_id"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="bottom"
        android:paddingStart="35sp"
        android:text="@string/login_id"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_login_title" />

    <View
        android:id="@+id/view_login_id_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginHorizontal="30dp"
        android:background="@color/line"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_login_id" />

    <TextView
        android:id="@+id/text_login_password"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="bottom"
        android:paddingStart="35sp"
        android:text="@string/login_password"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.08"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_login_id_line" />

    <View
        android:id="@+id/view_login_password_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginHorizontal="30dp"
        android:background="@color/line"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_login_password" />

    <Button
        android:id="@+id/button_login_login"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="15dp"
        android:text="@string/login_login"
        android:textColor="@color/button"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_login_password_line"
        app:layout_constraintWidth_percent="0.30" />

    <ImageView
        android:id="@+id/button_login_google"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="15dp"
        android:src="@drawable/ic_logo_google"
        app:layout_constraintEnd_toStartOf="@id/button_login_naver"
        app:layout_constraintHeight_percent="0.10"
        app:layout_constraintTop_toBottomOf="@id/button_login_login"
        app:layout_constraintWidth_percent="0.10" />

    <ImageView
        android:id="@+id/button_login_naver"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_logo_naver"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_login_login"
        app:layout_constraintWidth_percent="0.10" />

    <ImageView
        android:id="@+id/button_login_kakao"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="15dp"
        android:src="@drawable/ic_logo_kakao"
        app:layout_constraintHeight_percent="0.10"
        app:layout_constraintStart_toEndOf="@id/button_login_naver"
        app:layout_constraintTop_toBottomOf="@id/button_login_login"
        app:layout_constraintWidth_percent="0.10" />

    <TextView
        android:id="@+id/text_login_password_find"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="15dp"
        android:text="@string/login_findpassword"
        android:textSize="15sp"
        android:textColor="@color/text"
        app:layout_constraintEnd_toStartOf="@id/text_login_signup"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_login_naver" />

    <TextView
        android:id="@+id/text_login_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/login_signup"
        android:textSize="15sp"
        android:textColor="@color/text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/text_login_password_find"
        app:layout_constraintTop_toBottomOf="@id/button_login_naver" />

</androidx.constraintlayout.widget.ConstraintLayout>