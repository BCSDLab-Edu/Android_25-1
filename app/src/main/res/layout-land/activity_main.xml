<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backColor"
    >

    <TextView
        android:id="@+id/textview_social_login_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/textColor1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/edittext_social_login_id"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <EditText
        android:id="@+id/edittext_social_login_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:hint="@string/id"
        android:textColorHint="@color/hintColor1"
        app:layout_constraintBottom_toTopOf="@id/edittext_social_login_password"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <EditText
        android:id="@+id/edittext_social_login_password"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:hint="@string/password"
        android:textColorHint="@color/hintColor1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <Button
        android:id="@+id/button_social_login_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login"
        android:textColor="@color/textColor2"
        android:backgroundTint="@color/buttonColor1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edittext_social_login_password"
        />

    <ImageButton
        android:id="@+id/imagebutton_social_login_google"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_google"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:background="@color/nullColor"
        android:layout_margin="10dp"
        app:layout_constraintRight_toLeftOf="@id/imagebutton_social_login_naver"
        app:layout_constraintTop_toBottomOf="@id/button_social_login_login"
        />

    <ImageButton
        android:id="@+id/imagebutton_social_login_naver"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_naver"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:background="@color/nullColor"
        android:layout_margin="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/button_social_login_login"
        />

    <ImageButton
        android:id="@+id/imagebutton_social_login_kakao"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_logo_kakao"
        android:padding="0sp"
        android:scaleType="centerCrop"
        android:background="@color/nullColor"
        android:layout_margin="10dp"
        app:layout_constraintLeft_toRightOf="@id/imagebutton_social_login_naver"
        app:layout_constraintTop_toBottomOf="@id/button_social_login_login"
        />

    <Button
        android:id="@+id/button_social_login_find_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/nullColor"
        android:text="@string/findpw"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:paddingLeft="0dp"
        android:layout_marginTop="10dp"
        android:textColor="@color/textColor1"
        app:layout_constraintLeft_toLeftOf="@id/imagebutton_social_login_google"
        app:layout_constraintTop_toBottomOf="@id/imagebutton_social_login_google"
        />

    <Button
        android:id="@+id/button_social_login_create_account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/nullColor"
        android:text="@string/signup"
        android:textColor="@color/textColor1"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:paddingLeft="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintRight_toRightOf="@id/imagebutton_social_login_kakao"
        app:layout_constraintTop_toBottomOf="@id/imagebutton_social_login_kakao"
        />

</androidx.constraintlayout.widget.ConstraintLayout>