<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">


    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/login"
        android:textColor="@color/login_color"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/email_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="20dp"
        android:backgroundTint="#673AB7"
        android:hint="@string/id"
        android:textColorHint="@color/id_color"
        android:inputType="textEmailAddress"
        android:paddingBottom="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_text" />


    <EditText
        android:id="@+id/password_input"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="@string/password"
        android:textColorHint="@color/password_color"
        android:inputType="textPassword"
        android:backgroundTint="#673AB7"
        android:paddingBottom="15dp"
        app:layout_constraintTop_toBottomOf="@id/email_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp" />


    <Button
        android:id="@+id/login_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_button"
        android:textSize="20sp"
        android:backgroundTint="@color/login_button_background_color"
        android:textColor="@color/login_button_color"
        app:layout_constraintTop_toBottomOf="@id/password_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp" />






    <ImageView
        android:id="@+id/icon_google"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:srcCompat="@drawable/ic_logo_google"
        app:layout_constraintTop_toBottomOf="@id/login_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/icon_naver"
        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginTop="28dp"

        />


    <ImageView
        android:id="@+id/icon_naver"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toStartOf="@id/icon_kakao"
        app:layout_constraintStart_toEndOf="@id/icon_google"
        app:layout_constraintTop_toBottomOf="@id/login_button"
        app:srcCompat="@drawable/ic_logo_naver" />

    <ImageView
        android:id="@+id/icon_kakao"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:srcCompat="@drawable/ic_logo_kakao"
        app:layout_constraintTop_toBottomOf="@id/login_button"
        app:layout_constraintStart_toEndOf="@id/icon_naver"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"
        />


    <TextView
        android:id="@+id/find_password_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/forgot_password"
        android:textColor="@color/find_password_color"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/icon_google"
        app:layout_constraintStart_toStartOf="@+id/icon_google"
        app:layout_constraintTop_toBottomOf="@id/icon_google" />

    <TextView
        android:id="@+id/join_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/register"
        android:textColor="@color/join_passwrod_color"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@+id/icon_kakao"
        app:layout_constraintStart_toStartOf="@+id/icon_kakao"
        app:layout_constraintTop_toBottomOf="@id/icon_naver" />

</androidx.constraintlayout.widget.ConstraintLayout>
